---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/manrope";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/600.css";
import "../styles/base.css";

// Preload das fontes principais (latin-only) pra eliminar FOUT.
// Astro/Vite processa esses imports e retorna o URL final com hash.
import bricolageFontUrl from "@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url";
import manropeFontUrl from "@fontsource-variable/manrope/files/manrope-latin-wght-normal.woff2?url";
import jetbrainsFontUrl from "@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Astro — SkyBlock crossplay",
  description = "Servidor brasileiro de Minecraft SkyBlock. Java, Java pirata e Bedrock no mesmo lugar.",
} = Astro.props;

// Astro injeta a base path em import.meta.env.BASE_URL; isso garante que
// favicon.svg funcione tanto em / quanto em /astro/ (GitHub Pages).
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    {/* Preload das fontes principais — elimina FOUT (Flash of Unstyled
        Text) durante o primeiro paint. Browser começa download em
        paralelo com o HTML. */}
    <link rel="preload" href={bricolageFontUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={manropeFontUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jetbrainsFontUrl} as="font" type="font/woff2" crossorigin />

    {/* Preconnect a hosts SoundCloud — economiza DNS+TLS handshake. O
        widget consome múltiplos subdomínios; pré-aquecer reduz LCP do
        player de 2-5s pra ~1s. */}
    <link rel="preconnect" href="https://w.soundcloud.com" crossorigin />
    <link rel="preconnect" href="https://api-widget.soundcloud.com" crossorigin />
    <link rel="preconnect" href="https://api.soundcloud.com" crossorigin />
    <link rel="dns-prefetch" href="https://i1.sndcdn.com" />
    {/* Preload do script da iFrame Widget API — começa o download antes do parser chegar nele */}
    <link rel="preload" href="https://w.soundcloud.com/player/api.js" as="script" crossorigin />

    <title>{title}</title>

    {/* FOUC prevention — aplica data-theme antes do primeiro paint
        baseado em localStorage ou prefers-color-scheme. */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("astro-theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var theme = saved || (prefersDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", theme);
          var meta = document.createElement("meta");
          meta.name = "theme-color";
          meta.content = theme === "dark" ? "#07090F" : "#0B0F22";
          document.head.appendChild(meta);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <slot />
  </body>
</html>
