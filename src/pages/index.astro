---
import Base from "../layouts/Base.astro";
import Block from "../components/Block.astro";
import SpriteIsland from "../components/SpriteIsland.astro";
import PlayerHead from "../components/PlayerHead.astro";
import Starfield from "../components/Starfield.astro";
import Planet from "../components/Planet.astro";
import SunMoon from "../components/SunMoon.astro";
import Features from "../components/Features.astro";
import Shop from "../components/Shop.astro";
import Faq from "../components/Faq.astro";
import SoundCloudPlayer from "../components/SoundCloudPlayer.astro";

// Ilhas pixel-art posicionadas em zonas livres (planetas + UI).
// island-filter + island-opacity são vars do theme (dark = silhueta, light = vivo).
// `as const` preserva os literal types do variant pra checagem em SpriteIsland.
const islands = [
  { variant: "classic-l", size: 200, style: "bottom: 4%; left: 6%;" },
  { variant: "compact", size: 130, style: "bottom: 4%; right: 8%;" },
  { variant: "sand", size: 90, style: "top: 64%; right: 8%;" },
  { variant: "mini", size: 80, style: "top: 40%; left: 8%;" },
  { variant: "mini", size: 70, style: "top: 82%; left: 48%;" },
] as const;

// Endereço único do servidor — interpolado nos rails e CTA.
const SERVER_IP = "play.astro.gg";
const DISCORD_URL = "https://discord.gg/mqN6CvB8X";

const ports = [
  {
    n: "1",
    title: "Java original",
    block: "grass" as const,
    desc: "Conta Mojang/Microsoft. Todas as versões de 1.7 até a mais recente.",
    steps: ["Multiplayer · Adicionar Servidor", "Cole o endereço Java", "Entre"],
  },
  {
    n: "2",
    title: "Java pirata",
    block: "wood" as const,
    desc: "Sem conta Mojang. Login protegido com senha.",
    steps: [
      "Mesmo endereço Java",
      "Na primeira entrada: /register <senha> <senha>",
      "Nas próximas: /login <senha>",
    ],
  },
  {
    n: "3",
    title: "Bedrock",
    block: "bedrock" as const,
    desc: "Mobile, Switch, Xbox, PlayStation. Crossplay nativo.",
    steps: ["Servidores · Adicionar", "Cole o endereço Bedrock", "Auth automática — sem senha"],
  },
];

const community = ["steve", "alex", "pale", "dark", "amber", "green"];

const base = import.meta.env.BASE_URL || "/";
---

<Base title="Astro · SkyBlock crossplay">
  <div class="relative min-h-screen antialiased" style="font-family: var(--font-sans);">
    {/* ===== HERO ===== */}
    <section class="relative isolate overflow-hidden">
      {/* atmosfera de fundo — vars por tema (saturated: 3 radials + linear; moody: 2 radials + linear) */}
      <div
        class="pointer-events-none absolute inset-0 -z-20"
        style="background: var(--hero-bg);"
      ></div>

      {/* iso grid floor — visível só no modo dia (saturated) */}
      <svg
        class="pointer-events-none absolute inset-0 -z-10 h-full w-full"
        style="opacity: var(--iso-grid-opacity);"
        viewBox="0 0 1600 900"
        preserveAspectRatio="xMidYMax slice"
        aria-hidden="true"
      >
        <defs>
          <pattern id="iso-floor" width="80" height="46" patternUnits="userSpaceOnUse">
            <path d="M 0 23 L 40 0 L 80 23 L 40 46 Z" fill="none" stroke="#6FE89C" stroke-width="0.4" />
          </pattern>
        </defs>
        <rect x="0" y="500" width="1600" height="400" fill="url(#iso-floor)" />
      </svg>

      <Starfield count={180} palette="moody" seed={23} class="-z-10" />

      {/* SOL/LUA — cresce com tema */}
      <div class="hidden md:block">
        <SunMoon size={130} />
      </div>
      <div class="md:hidden">
        <SunMoon size={90} />
      </div>

      {/* planetas decorativos (mantém constante entre temas, mais centrais) */}
      {/* Saturn no canto esquerdo superior — longe do sol/lua que estão à direita */}
      <div class="pointer-events-none absolute -z-10 hidden md:block" style="top: 5%; left: 5%;">
        <Planet size={130} palette="saturn" ring glow="rgba(232, 185, 92, 0.35)" />
      </div>
      <div class="pointer-events-none absolute -z-10 hidden md:block" style="top: 36%; left: 6%;">
        <Planet size={90} palette="ice" glow="rgba(184, 216, 232, 0.25)" />
      </div>
      <div class="pointer-events-none absolute -z-10 hidden md:block" style="top: 28%; left: 30%;">
        <Planet size={50} palette="mars" />
      </div>
      <div class="pointer-events-none absolute -z-10 hidden md:block" style="top: 50%; right: 16%;">
        <Planet size={80} palette="void" glow="rgba(179, 128, 232, 0.4)" />
      </div>

      {/* ilhas pixel-art */}
      <div class="pointer-events-none absolute inset-0 z-20 hidden md:block">
        {
          islands.map((isl) => (
            <div
              class="absolute"
              style={`${isl.style} opacity: var(--island-opacity); filter: var(--island-filter);`}
            >
              <SpriteIsland variant={isl.variant} size={isl.size} />
            </div>
          ))
        }
      </div>

      {/* mist + vignette */}
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-1/3"
        style="background: var(--mist);"
      ></div>
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: var(--vignette);"
      ></div>

      {/* nav */}
      <header class="relative z-30">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 md:px-10">
          <a href={base} class="flex items-center gap-2.5" style="color: var(--text);">
            <span class="inline-block h-3 w-3" style="background: var(--accent);"></span>
            <span class="display text-xl font-bold tracking-tight">astro</span>
          </a>
          <nav
            class="hidden items-center gap-8 mono text-[0.7rem] font-medium tracking-[0.15em] uppercase md:flex"
            style="color: var(--text-dim);"
          >
            <a href="#conectar" class="hover:opacity-100" style="opacity: 0.85;">Conectar</a>
            <a href="#sistema" class="hover:opacity-100" style="opacity: 0.85;">Sistema</a>
            <a href="#loja" class="hover:opacity-100" style="opacity: 0.85;">Loja</a>
            <a href="#faq" class="hover:opacity-100" style="opacity: 0.85;">FAQ</a>
          </nav>

          {/* THEME TOGGLE */}
          <button
            type="button"
            data-theme-toggle
            aria-label="Alternar tema claro/escuro"
            class="theme-toggle relative inline-flex h-9 w-9 items-center justify-center border backdrop-blur-sm transition-colors hover:opacity-80"
            style="border-color: var(--border); background: var(--card-strong); color: var(--accent);"
          >
            <svg
              class="icon-sun absolute h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="M4.93 4.93l1.41 1.41" />
              <path d="M17.66 17.66l1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="M4.93 19.07l1.41-1.41" />
              <path d="M17.66 6.34l1.41-1.41" />
            </svg>
            <svg
              class="icon-moon absolute h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        </div>
      </header>

      {/* hero content */}
      <div class="relative z-10 mx-auto max-w-5xl px-6 pt-16 pb-32 text-center md:pt-24 md:pb-44">
        <div
          class="inline-flex items-center gap-3 border px-4 py-1.5 backdrop-blur-sm"
          style="border-color: var(--accent-soft); background: var(--card-strong);"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-60"
              style="background: var(--status-online);"
            ></span>
            <span
              class="relative inline-flex h-2 w-2 rounded-full"
              style="background: var(--status-online);"
            ></span>
          </span>
          <span
            class="mono text-[0.7rem] font-semibold tracking-[0.25em] uppercase"
            style="color: var(--accent);"
          >
            servidor online
          </span>
        </div>

        <h1
          class="display-tight mt-10 text-[clamp(5rem,18vw,12rem)] font-extrabold uppercase"
          style="background: var(--title-bg); -webkit-background-clip: text; background-clip: text; color: var(--title-color); text-shadow: var(--title-shadow);"
        >
          Astro
        </h1>

        <p
          class="mono mt-5 text-sm font-medium tracking-[0.3em] uppercase md:text-base"
          style="color: var(--text-dim);"
        >
          skyblock cósmico · crossplay
        </p>

        <div
          class="mx-auto mt-8 h-px w-24"
          style="background: linear-gradient(to right, transparent, var(--accent-soft), transparent); opacity: var(--divider-opacity);"
        ></div>

        <p
          class="mx-auto mt-8 max-w-md text-base leading-relaxed md:text-lg"
          style="color: var(--text-dim);"
        >
          Sua ilha em órbita. Java, pirata e Bedrock
          no mesmo sistema solar.
        </p>

        <button
          type="button"
          data-copy-hero
          data-addr={SERVER_IP}
          class="group mx-auto mt-12 flex w-full max-w-md items-stretch overflow-hidden hover:scale-[1.02]"
          style="background: var(--btn-cta-bg); color: var(--btn-cta-text); box-shadow: var(--btn-cta-shadow);"
        >
          <span
            class="flex items-center justify-center px-5"
            style="background: var(--btn-icon-bg);"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 16 16"
              fill="currentColor"
              style="color: var(--accent);"
              aria-hidden="true"
            >
              <path d="M3 2 L13 8 L3 14 Z" />
            </svg>
          </span>
          <span class="flex flex-1 flex-col items-start justify-center px-5 py-3 text-left">
            <span
              class="mono text-[0.55rem] font-semibold tracking-[0.25em] uppercase opacity-70"
              data-copy-hero-label
            >
              clique para copiar
            </span>
            <span class="mono text-lg font-bold md:text-xl" data-copy-hero-text>
              {SERVER_IP}
            </span>
          </span>
          <span class="flex items-center justify-center px-5">
            <svg
              class="h-4 w-4"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <rect x="4.5" y="4.5" width="8" height="8" rx="1" />
              <path d="M3 11 L3 3 L11 3" />
            </svg>
          </span>
        </button>

        <div class="mt-12 flex flex-col items-center justify-center gap-5 md:flex-row md:gap-10">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              {
                community.map((p, i) => (
                  <div
                    class="ring-2 transition-transform hover:-translate-y-1"
                    style={`z-index: ${community.length - i}; --tw-ring-color: var(--bg-base);`}
                  >
                    <PlayerHead palette={p} size={28} />
                  </div>
                ))
              }
            </div>
            <span
              class="mono text-[0.65rem] tracking-[0.2em] uppercase"
              style="color: var(--text-dim);"
            >
              comunidade ativa
            </span>
          </div>

          <span class="hidden h-3 w-px md:block" style="background: var(--border);"></span>

          <div
            class="mono text-[0.65rem] tracking-[0.2em] uppercase"
            style="color: var(--text-muted);"
          >
            <span style="color: var(--text);">1.21.x</span> · via 1.7+
          </div>
        </div>
      </div>

      <div
        class="pointer-events-none absolute bottom-0 left-0 right-0 h-24"
        style="background: linear-gradient(to bottom, transparent, var(--bg-base));"
      ></div>
    </section>

    {/* ===== CONNECT ===== */}
    <section
      id="conectar"
      class="relative scroll-mt-20 px-6 py-20 md:px-10 md:py-28"
      style="background: var(--bg-base);"
    >
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <div
              class="mono text-xs font-semibold tracking-[0.25em] uppercase"
              style="color: var(--accent);"
            >
              ▸ como conectar
            </div>
            <h2 class="display mt-3 text-4xl font-extrabold md:text-5xl" style="color: var(--text);">
              Mesmo IP. Três jeitos.
            </h2>
          </div>
          <p class="mono max-w-md text-sm" style="color: var(--text-dim);">
            O servidor identifica sua plataforma e ajusta o login automaticamente.
          </p>
        </div>

        <div class="mb-8">
          <button
            type="button"
            data-copy-rail
            data-addr={SERVER_IP}
            class="group flex w-full items-stretch overflow-hidden border backdrop-blur-sm hover:opacity-90"
            style="border-color: var(--border); background: var(--card-strong);"
          >
            <span
              class="flex items-center justify-center px-4 mono text-[0.6rem] font-bold tracking-[0.2em] uppercase"
              style="background: var(--bg-alt); color: var(--accent);"
            >
              Java · Bedrock
            </span>
            <span class="flex flex-1 items-center justify-between px-5 py-3 text-left">
              <span class="mono text-base font-bold md:text-lg" style="color: var(--text);">
                {SERVER_IP}
              </span>
              <span class="mono text-[0.65rem] tracking-[0.2em] uppercase" style="color: var(--text-muted);">
                porta automática
              </span>
            </span>
            <span
              class="flex items-center justify-center border-l px-4 mono text-[0.7rem] font-bold tracking-[0.2em] uppercase"
              style="border-color: var(--border); color: var(--text-dim);"
              data-copy-rail-label
            >
              copiar
            </span>
          </button>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {
            ports.map((p) => (
              <article
                class="group relative flex flex-col gap-5 border p-6 backdrop-blur-sm"
                style="border-color: var(--border); background: var(--card);"
              >
                <header class="flex items-center justify-between">
                  <span
                    class="mono text-xs font-bold tracking-[0.25em] uppercase"
                    style="color: var(--text-muted);"
                  >
                    passo 0{p.n}
                  </span>
                </header>

                <div class="flex items-center gap-4">
                  <div class="shrink-0 transition-transform duration-500 group-hover:-translate-y-1 group-hover:rotate-3">
                    <Block palette={p.block} size={56} />
                  </div>
                  <h3 class="display text-2xl font-extrabold" style="color: var(--text);">
                    {p.title}
                  </h3>
                </div>

                <p class="text-sm leading-relaxed" style="color: var(--text-dim);">
                  {p.desc}
                </p>

                <ol
                  class="mono space-y-2 border-t pt-4 text-[0.75rem]"
                  style="border-color: var(--border); color: var(--text-dim);"
                >
                  {p.steps.map((s, i) => (
                    <li class="flex items-start gap-3">
                      <span
                        class="mt-0.5 inline-flex h-4 w-4 shrink-0 items-center justify-center text-[0.55rem] font-bold"
                        style="background: var(--bg-alt); color: var(--text);"
                      >
                        {i + 1}
                      </span>
                      <span>{s}</span>
                    </li>
                  ))}
                </ol>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    {/* ===== SISTEMA ===== */}
    <Features />

    {/* ===== LOJA ===== */}
    <Shop />

    {/* ===== FAQ ===== */}
    <Faq />

    {/* ===== FOOTER ===== */}
    <footer
      class="border-t px-6 py-10 md:px-10"
      style="border-color: var(--border); background: var(--bg-deep);"
    >
      <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 md:flex-row">
        <div class="display flex items-center gap-2 text-lg font-bold" style="color: var(--text);">
          <span class="inline-block h-2.5 w-2.5" style="background: var(--accent);"></span>
          <span>astro</span>
        </div>

        <nav class="flex items-center gap-5" aria-label="Links sociais">
          <a
            href={DISCORD_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="mono inline-flex items-center gap-2 text-[0.7rem] font-bold tracking-[0.15em] uppercase hover:opacity-80"
            style="color: var(--accent);"
            aria-label="Entrar no Discord do servidor"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.27 5.33A19.5 19.5 0 0 0 14.5 4l-.21.42a17.85 17.85 0 0 0-4.58 0L9.5 4a19.5 19.5 0 0 0-4.77 1.33A20.2 20.2 0 0 0 1.5 18.5a19.7 19.7 0 0 0 5.96 3l.93-1.28a13.05 13.05 0 0 1-2.05-.99l.5-.39a14 14 0 0 0 11.32 0l.5.39a13.05 13.05 0 0 1-2.05.99l.93 1.28a19.7 19.7 0 0 0 5.96-3 20.2 20.2 0 0 0-3.23-13.17ZM8.52 15.33c-1.17 0-2.13-1.08-2.13-2.4 0-1.31.94-2.39 2.13-2.39 1.18 0 2.14 1.08 2.13 2.4 0 1.31-.95 2.39-2.13 2.39Zm6.96 0c-1.17 0-2.13-1.08-2.13-2.4 0-1.31.94-2.39 2.13-2.39 1.18 0 2.14 1.08 2.13 2.4 0 1.31-.94 2.39-2.13 2.39Z" />
            </svg>
            <span>discord</span>
          </a>
        </nav>

        <div
          class="mono text-[0.65rem] tracking-[0.2em] uppercase"
          style="color: var(--text-muted);"
        >
          Servidor brasileiro · não afiliado à Mojang ou Microsoft
        </div>
      </div>
    </footer>

    {/* grain */}
    <div class="grain-overlay fixed inset-0"></div>

    {/* Spotify floating player */}
    <SoundCloudPlayer />
  </div>

  <script>
    function setup() {
      // ===== THEME TOGGLE =====
      const root = document.documentElement;
      const STORAGE_KEY = "astro-theme";

      document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", () => {
          const current = root.getAttribute("data-theme") || "dark";
          const next = current === "dark" ? "light" : "dark";
          root.setAttribute("data-theme", next);
          try {
            localStorage.setItem(STORAGE_KEY, next);
          } catch (e) {}
          // Atualiza theme-color meta pro browser chrome (mobile)
          const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
          if (meta) meta.content = next === "dark" ? "#07090F" : "#0B0F22";
        });
      });

      // ===== HERO IP COPY =====
      // Endereço vem do data-addr (frontmatter SERVER_IP) — fonte única.
      document.querySelectorAll<HTMLButtonElement>("[data-copy-hero]").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", async () => {
          const label = btn.querySelector<HTMLElement>("[data-copy-hero-label]");
          const addr = btn.dataset.addr ?? "";
          try {
            await navigator.clipboard.writeText(addr);
            if (label) {
              const prev = label.textContent;
              label.textContent = "copiado ✓";
              setTimeout(() => {
                if (label) label.textContent = prev;
              }, 1800);
            }
          } catch (e) {}
        });
      });

      // ===== RAIL COPY (Java + Bedrock) =====
      document.querySelectorAll<HTMLButtonElement>("[data-copy-rail]").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", async () => {
          const label = btn.querySelector<HTMLElement>("[data-copy-rail-label]");
          const addr = btn.dataset.addr ?? "";
          const port = btn.dataset.port;
          const text = port ? `${addr}:${port}` : addr;
          try {
            await navigator.clipboard.writeText(text);
            if (label) {
              const prev = label.textContent;
              label.textContent = "copiado ✓";
              setTimeout(() => {
                if (label) label.textContent = prev;
              }, 1500);
            }
          } catch (e) {}
        });
      });
    }
    setup();
    document.addEventListener("astro:page-load", setup);
  </script>
</Base>
