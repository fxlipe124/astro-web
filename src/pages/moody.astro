---
import Base from "../layouts/Base.astro";
import Block from "../components/Block.astro";
import SpriteIsland from "../components/SpriteIsland.astro";
import PlayerHead from "../components/PlayerHead.astro";
import Starfield from "../components/Starfield.astro";
import Planet from "../components/Planet.astro";
import Features from "../components/Features.astro";
import Shop from "../components/Shop.astro";
import Faq from "../components/Faq.astro";

// silhouetted SkyBlock islands — positioned in zones free of planets + UI elements
const islands = [
  { variant: "classic-l", size: 200, style: "bottom: 2%; left: 0%; opacity: 0.85; filter: brightness(0.55);" },
  { variant: "compact", size: 130, style: "bottom: 2%; right: 0%; opacity: 0.85; filter: brightness(0.55);" },
  { variant: "sand", size: 90, style: "top: 56%; right: 1%; opacity: 0.8; filter: brightness(0.6);" },
  { variant: "mini", size: 80, style: "top: 38%; left: 1%; opacity: 0.7; filter: brightness(0.55);" },
  { variant: "mini", size: 70, style: "top: 82%; left: 50%; opacity: 0.7; filter: brightness(0.55);" },
];

const ports = [
  {
    n: "1",
    title: "Java original",
    block: "grass" as const,
    desc: "Conta Mojang/Microsoft. Todas as versões de 1.7 até a mais recente.",
    steps: [
      "Multiplayer · Adicionar Servidor",
      "Cole o endereço Java",
      "Entre",
    ],
  },
  {
    n: "2",
    title: "Java pirata",
    block: "wood" as const,
    desc: "Sem conta Mojang. Login protegido com senha.",
    steps: [
      "Mesmo endereço Java",
      "Na primeira entrada: /register <senha> <senha>",
      "Nas próximas: /login <senha>",
    ],
  },
  {
    n: "3",
    title: "Bedrock",
    block: "bedrock" as const,
    desc: "Mobile, Switch, Xbox, PlayStation. Crossplay nativo.",
    steps: [
      "Servidores · Adicionar",
      "Cole o endereço Bedrock",
      "Auth automática — sem senha",
    ],
  },
];

const community = ["steve", "alex", "pale", "dark", "amber", "green"];

// Base path pro nav (GitHub Pages serve em /astro/)
const base = import.meta.env.BASE_URL || "/";
---

<Base title="Astro · SkyBlock crossplay (moody)" themeColor="#07090F">
  <div class="relative min-h-screen text-[#F2EBD8] antialiased" style="background: #07090F; font-family: var(--font-sans);">
    {/* ===== HERO ===== */}
    <section class="relative isolate overflow-hidden">
      {/* base atmosphere */}
      <div
        class="pointer-events-none absolute inset-0 -z-20"
        style="background:
          radial-gradient(ellipse 60% 40% at 80% 20%, rgba(232, 185, 92, 0.18), transparent 65%),
          radial-gradient(ellipse 70% 50% at 30% 80%, rgba(74, 120, 88, 0.15), transparent 70%),
          linear-gradient(180deg, #07090F 0%, #0F1320 60%, #07090F 100%);"
      ></div>

      <Starfield count={180} palette="moody" seed={23} class="-z-10" />

      <div
        class="pointer-events-none absolute -z-10 hidden md:block"
        style="top: 4%; right: 2%; transform: rotate(-8deg);"
        aria-hidden="true"
      >
        <Planet size={380} palette="saturn" ring glow="rgba(232, 185, 92, 0.35)" />
      </div>

      <div class="pointer-events-none absolute -z-10 hidden md:block" style="top: 22%; left: 6%;">
        <Planet size={90} palette="ice" glow="rgba(184, 216, 232, 0.25)" />
      </div>

      <div class="pointer-events-none absolute -z-10 hidden md:block" style="top: 14%; left: 32%;">
        <Planet size={50} palette="mars" />
      </div>

      <div
        class="pointer-events-none absolute -z-10 md:hidden"
        style="top: 4%; right: -8%; transform: rotate(-8deg);"
        aria-hidden="true"
      >
        <Planet size={180} palette="saturn" ring glow="rgba(232, 185, 92, 0.4)" />
      </div>

      <div class="pointer-events-none absolute inset-0 z-20 hidden md:block">
        {
          islands.map((isl) => (
            <div class="absolute" style={isl.style}>
              <SpriteIsland variant={isl.variant as any} size={isl.size} />
            </div>
          ))
        }
      </div>

      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-1/3"
        style="background: linear-gradient(180deg, transparent 0%, rgba(15, 19, 32, 0.9) 60%, #07090F 100%);"
      ></div>

      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 40%, rgba(7, 9, 15, 0.7) 100%);"
      ></div>

      {/* nav */}
      <header class="relative z-10">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 md:px-10">
          <a href={base} class="flex items-center gap-2.5 text-[#F2EBD8]">
            <span class="inline-block h-3 w-3 bg-[#E8B95C]"></span>
            <span class="display text-xl font-bold tracking-tight">astro</span>
          </a>
          <nav class="hidden items-center gap-8 mono text-[0.7rem] font-medium tracking-[0.15em] text-[#9A8E70] uppercase md:flex">
            <a href="#conectar" class="transition-colors hover:text-[#F2EBD8]">Conectar</a>
            <a href="#sistema" class="transition-colors hover:text-[#F2EBD8]">Sistema</a>
            <a href="#loja" class="transition-colors hover:text-[#F2EBD8]">Loja</a>
            <a href="#faq" class="transition-colors hover:text-[#F2EBD8]">FAQ</a>
          </nav>
          <a
            href={base}
            class="mono inline-flex items-center gap-2 border border-[#28304A] bg-[#131826]/60 px-3 py-1.5 text-[0.65rem] font-medium tracking-[0.15em] text-[#9A8E70] uppercase backdrop-blur-sm transition-colors hover:border-[#E8B95C]/50 hover:text-[#F2EBD8]"
          >
            ← versão padrão
          </a>
        </div>
      </header>

      {/* hero content */}
      <div class="relative z-10 mx-auto max-w-5xl px-6 pt-16 pb-32 text-center md:pt-24 md:pb-44">
        <div class="inline-flex items-center gap-3 border border-[#E8B95C]/25 bg-[#131826]/60 px-4 py-1.5 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#E8B95C] opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[#E8B95C]"></span>
          </span>
          <span class="mono text-[0.7rem] font-semibold tracking-[0.25em] text-[#E8B95C] uppercase">
            servidor online
          </span>
        </div>

        <h1
          class="display-tight mt-10 text-[clamp(5rem,18vw,12rem)] font-extrabold uppercase text-[#F2EBD8]"
          style="text-shadow: 0 4px 60px rgba(232, 185, 92, 0.35), 0 0 120px rgba(232, 185, 92, 0.15);"
        >
          Astro
        </h1>

        <p class="mono mt-5 text-sm font-medium tracking-[0.3em] text-[#9A8E70] uppercase md:text-base">
          skyblock cósmico · crossplay
        </p>

        <div class="mx-auto mt-8 h-px w-24 bg-gradient-to-r from-transparent via-[#E8B95C]/40 to-transparent"></div>

        <p class="mx-auto mt-8 max-w-md text-base leading-relaxed text-[#9A8E70] md:text-lg">
          Sua ilha em órbita. Java, pirata e Bedrock
          no mesmo sistema solar.
        </p>

        <button
          type="button"
          data-copy-hero
          class="group mx-auto mt-12 flex w-full max-w-md items-stretch overflow-hidden bg-[#E8B95C] text-[#07090F] transition-all hover:scale-[1.02] hover:bg-[#F2DCA0]"
          style="box-shadow: 0 0 40px 0 rgba(232, 185, 92, 0.4), 0 0 0 1px rgba(232, 185, 92, 0.5) inset;"
        >
          <span class="flex items-center justify-center bg-[#07090F] px-5">
            <svg class="h-5 w-5 text-[#E8B95C]" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M3 2 L13 8 L3 14 Z" />
            </svg>
          </span>
          <span class="flex flex-1 flex-col items-start justify-center px-5 py-3 text-left">
            <span class="mono text-[0.55rem] font-semibold tracking-[0.25em] uppercase opacity-70" data-copy-hero-label>
              clique para copiar
            </span>
            <span class="mono text-lg font-bold md:text-xl" data-copy-hero-text>
              play.astro.gg
            </span>
          </span>
          <span class="flex items-center justify-center px-5">
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="4.5" y="4.5" width="8" height="8" rx="1" />
              <path d="M3 11 L3 3 L11 3" />
            </svg>
          </span>
        </button>

        <div class="mt-12 flex flex-col items-center justify-center gap-5 md:flex-row md:gap-10">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              {
                community.map((p, i) => (
                  <div class="ring-2 ring-[#07090F] transition-transform hover:-translate-y-1" style={`z-index: ${community.length - i};`}>
                    <PlayerHead palette={p} size={28} />
                  </div>
                ))
              }
            </div>
            <span class="mono text-[0.65rem] tracking-[0.2em] text-[#9A8E70] uppercase">
              comunidade ativa
            </span>
          </div>

          <span class="hidden h-3 w-px bg-[#28304A] md:block"></span>

          <div class="mono text-[0.65rem] tracking-[0.2em] text-[#5C5340] uppercase">
            <span class="text-[#F2EBD8]">1.21.x</span> · via 1.7+
          </div>
        </div>
      </div>

      <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-b from-transparent to-[#07090F]"></div>
    </section>

    {/* ===== CONNECT ===== */}
    <section id="conectar" class="relative scroll-mt-20 px-6 py-20 md:px-10 md:py-28" style="background: #07090F;">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <div class="mono text-xs font-semibold tracking-[0.25em] text-[#E8B95C] uppercase">
              ▸ como conectar
            </div>
            <h2 class="display mt-3 text-4xl font-extrabold text-[#F2EBD8] md:text-5xl">
              Mesmo IP. Três jeitos.
            </h2>
          </div>
          <p class="mono max-w-md text-sm text-[#9A8E70]">
            O servidor identifica sua plataforma e ajusta o login automaticamente.
          </p>
        </div>

        <div class="mb-8 grid gap-3 md:grid-cols-2">
          <button
            type="button"
            data-copy-rail
            data-addr="play.astro.gg"
            class="group flex items-stretch overflow-hidden border border-[#28304A] bg-[#131826]/70 backdrop-blur-sm transition-colors hover:border-[#E8B95C]/50"
          >
            <span class="flex items-center justify-center bg-[#1F2535] px-4 mono text-[0.6rem] font-bold tracking-[0.2em] text-[#E8B95C] uppercase">
              Java
            </span>
            <span class="flex flex-1 items-center justify-between px-5 py-3 text-left">
              <span class="mono text-base font-bold text-[#F2EBD8] md:text-lg">play.astro.gg</span>
              <span class="mono text-[0.65rem] tracking-[0.2em] text-[#5C5340] uppercase">porta 25565</span>
            </span>
            <span class="flex items-center justify-center border-l border-[#28304A] px-4 mono text-[0.7rem] font-bold tracking-[0.2em] text-[#9A8E70] uppercase transition-colors group-hover:bg-[#E8B95C] group-hover:text-[#07090F]" data-copy-rail-label>
              copiar
            </span>
          </button>

          <button
            type="button"
            data-copy-rail
            data-addr="play.astro.gg"
            data-port="19132"
            class="group flex items-stretch overflow-hidden border border-[#28304A] bg-[#131826]/70 backdrop-blur-sm transition-colors hover:border-[#E8B95C]/50"
          >
            <span class="flex items-center justify-center bg-[#1F2535] px-4 mono text-[0.6rem] font-bold tracking-[0.2em] text-[#B8D8E8] uppercase">
              Bedrock
            </span>
            <span class="flex flex-1 items-center justify-between px-5 py-3 text-left">
              <span class="mono text-base font-bold text-[#F2EBD8] md:text-lg">play.astro.gg</span>
              <span class="mono text-[0.65rem] tracking-[0.2em] text-[#5C5340] uppercase">porta 19132</span>
            </span>
            <span class="flex items-center justify-center border-l border-[#28304A] px-4 mono text-[0.7rem] font-bold tracking-[0.2em] text-[#9A8E70] uppercase transition-colors group-hover:bg-[#B8D8E8] group-hover:text-[#07090F]" data-copy-rail-label>
              copiar
            </span>
          </button>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {
            ports.map((p) => (
              <article
                class="group relative flex flex-col gap-5 border border-[#28304A] bg-[#131826]/40 p-6 backdrop-blur-sm transition-colors hover:border-[#E8B95C]/30"
              >
                <header class="flex items-center justify-between">
                  <span class="mono text-xs font-bold tracking-[0.25em] text-[#5C5340]">
                    passo 0{p.n}
                  </span>
                </header>

                <div class="flex items-center gap-4">
                  <div class="shrink-0 transition-transform duration-500 group-hover:-translate-y-1 group-hover:rotate-3">
                    <Block palette={p.block} size={56} />
                  </div>
                  <h3 class="display text-2xl font-extrabold text-[#F2EBD8]">
                    {p.title}
                  </h3>
                </div>

                <p class="text-sm leading-relaxed text-[#9A8E70]">{p.desc}</p>

                <ol class="mono space-y-2 border-t border-[#28304A] pt-4 text-[0.75rem] text-[#9A8E70]">
                  {p.steps.map((s, i) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-0.5 inline-flex h-4 w-4 shrink-0 items-center justify-center bg-[#1A2030] text-[0.55rem] font-bold text-[#F2EBD8]">
                        {i + 1}
                      </span>
                      <span>{s}</span>
                    </li>
                  ))}
                </ol>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    {/* ===== SISTEMA ===== */}
    <Features theme="moody" />

    {/* ===== LOJA ===== */}
    <Shop theme="moody" />

    {/* ===== FAQ ===== */}
    <Faq theme="moody" />

    {/* ===== FOOTER ===== */}
    <footer class="border-t border-[#1A2030] bg-[#04060B] px-6 py-10 md:px-10">
      <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-3 md:flex-row">
        <div class="display flex items-center gap-2 text-lg font-bold text-[#F2EBD8]">
          <span class="inline-block h-2.5 w-2.5 bg-[#E8B95C]"></span>
          <span>astro</span>
        </div>
        <div class="mono text-[0.65rem] tracking-[0.2em] text-[#5C5340] uppercase">
          Servidor brasileiro · não afiliado à Mojang ou Microsoft
        </div>
      </div>
    </footer>

    {/* grain */}
    <div class="grain-overlay fixed inset-0"></div>
  </div>

  <script>
    function setup() {
      document.querySelectorAll<HTMLButtonElement>("[data-copy-hero]").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", async () => {
          const label = btn.querySelector<HTMLElement>("[data-copy-hero-label]");
          try {
            await navigator.clipboard.writeText("play.astro.gg");
            if (label) {
              const prev = label.textContent;
              label.textContent = "copiado ✓";
              setTimeout(() => { if (label) label.textContent = prev; }, 1800);
            }
          } catch (e) {}
        });
      });

      document.querySelectorAll<HTMLButtonElement>("[data-copy-rail]").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", async () => {
          const label = btn.querySelector<HTMLElement>("[data-copy-rail-label]");
          const addr = btn.dataset.addr ?? "play.astro.gg";
          const port = btn.dataset.port;
          const text = port ? `${addr}:${port}` : addr;
          try {
            await navigator.clipboard.writeText(text);
            if (label) {
              const prev = label.textContent;
              label.textContent = "copiado ✓";
              setTimeout(() => { if (label) label.textContent = prev; }, 1500);
            }
          } catch (e) {}
        });
      });
    }
    setup();
    document.addEventListener("astro:page-load", setup);
  </script>
</Base>
