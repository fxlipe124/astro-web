---
import Block from "./Block.astro";

// Tiers reais — extraídos de docs/decisoes-de-produto.md §1 e
// skripts/skyblock/luckperms-hierarchy.sk. Cores espelham os prefixos
// no chat (Nova verde, Hyper vermelho, Apex branco, Astro rosa em negrito).
const tiers = [
  {
    n: "1",
    name: "Nova",
    block: "emerald" as const,
    tagColor: "#55FF55",
    tag: "[NOVA]",
    blurb: "Primeiro tier de apoio.",
    cmds: ["/heal"],
    homes: 3,
    kit: "kit_nova · 12h",
  },
  {
    n: "2",
    name: "Nova+",
    block: "emerald" as const,
    tagColor: "#55FF55",
    tag: "[NOVA+]",
    blurb: "Nova com fome cheia.",
    cmds: ["/heal", "/feed"],
    homes: 4,
    kit: "kit_novaplus · 8h",
  },
  {
    n: "3",
    name: "Hyper",
    block: "redstone" as const,
    tagColor: "#FF5555",
    tag: "[HYPER]",
    blurb: "Reparo direto na bancada.",
    cmds: ["/heal", "/feed", "/repair"],
    homes: 5,
    kit: "kit_hyper · 6h",
  },
  {
    n: "4",
    name: "Hyper+",
    block: "redstone" as const,
    tagColor: "#FF5555",
    tag: "[HYPER+]",
    blurb: "Decola na sua ilha.",
    cmds: ["/heal", "/feed", "/repair", "/fly"],
    homes: 6,
    kit: "kit_hyperplus · 4h",
  },
  {
    n: "5",
    name: "Apex",
    block: "diamond" as const,
    tagColor: "#FFFFFF",
    tag: "[APEX]",
    blurb: "Workshop e ender-chest portáteis.",
    cmds: ["+ /workbench", "+ /enderchest", "+ /near"],
    homes: 8,
    kit: "kit_apex · 2h",
  },
  {
    n: "6",
    name: "Astro",
    block: "amethyst" as const,
    tagColor: "#FF55FF",
    tag: "[ASTRO]",
    blurb: "Top donor. Mesmo nome do servidor.",
    cmds: ["+ /more", "+ /book", "+ /invsee"],
    homes: 10,
    kit: "kit_astro · 1h",
    featured: true,
    extra: "Aura Estelar exclusiva — efeito de partículas + farm AFK ligado por /aura.",
  },
];
---

<section
  id="loja"
  class="relative scroll-mt-20 px-6 py-20 md:px-10 md:py-28"
  style="background: var(--bg-alt);"
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <div
          class="mono text-xs font-semibold tracking-[0.25em] uppercase"
          style="color: var(--accent);"
        >
          ▸ loja
        </div>
        <h2
          class="display mt-3 text-4xl font-extrabold md:text-5xl"
          style="color: var(--text);"
        >
          Seis tiers de apoio.
        </h2>
      </div>
      <p class="mono max-w-md text-sm" style="color: var(--text-dim);">
        Tiers aceleram progressão e adicionam conveniências. Comprar não é obrigatório — o jogo flui sem eles, mas ajuda quem ajuda.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        tiers.map((tier) => (
          <article
            class:list={[
              "group relative flex flex-col gap-4 border p-6 transition-all duration-300 hover:-translate-y-1",
              tier.featured ? "lg:scale-[1.03]" : "",
            ]}
            style={`background: ${tier.featured ? "var(--card-feature)" : "var(--card)"}; border-color: ${tier.featured ? tier.tagColor + "66" : "var(--border)"}; ${tier.featured ? `box-shadow: 0 12px 40px -8px ${tier.tagColor}55;` : ""}`}
          >
            {tier.featured && (
              <span
                class="absolute -top-3 left-1/2 -translate-x-1/2 mono px-3 py-0.5 text-[0.6rem] font-bold tracking-[0.25em] uppercase"
                style={`background: var(--bg-alt); color: ${tier.tagColor};`}
              >
                ✦ top donor
              </span>
            )}

            <header class="flex items-center justify-between">
              <span
                class="mono text-[0.6rem] font-bold tracking-[0.25em] uppercase"
                style="color: var(--text-muted);"
              >
                tier 0{tier.n}
              </span>
              <span
                class="mono inline-block px-2 py-0.5 text-[0.6rem] font-bold tracking-[0.15em]"
                style={`background: ${tier.tagColor}22; color: ${tier.tagColor}; border: 1px solid ${tier.tagColor}55;`}
              >
                {tier.tag}
              </span>
            </header>

            <div class="flex items-center gap-3">
              <div class="shrink-0 transition-transform duration-500 group-hover:-translate-y-1 group-hover:rotate-3">
                <Block palette={tier.block} size={48} />
              </div>
              <div>
                <h3
                  class="display text-xl font-extrabold leading-tight md:text-2xl"
                  style="color: var(--text);"
                >
                  {tier.name}
                </h3>
                <p class="mt-0.5 text-xs" style="color: var(--text-dim);">
                  {tier.blurb}
                </p>
              </div>
            </div>

            <div class="h-px" style="background: var(--border);" />

            <dl class="space-y-2.5 text-sm" style="color: var(--text-dim);">
              <div class="flex items-baseline justify-between gap-3">
                <dt class="mono text-[0.6rem] tracking-[0.2em] uppercase shrink-0" style="color: var(--text-muted);">
                  comandos
                </dt>
                <dd class="mono text-right text-[0.7rem]" style="color: var(--text);">
                  {tier.cmds.join(" ")}
                </dd>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="mono text-[0.6rem] tracking-[0.2em] uppercase shrink-0" style="color: var(--text-muted);">
                  /sethome
                </dt>
                <dd class="mono text-right text-[0.7rem]" style="color: var(--text);">
                  {tier.homes} slots
                </dd>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="mono text-[0.6rem] tracking-[0.2em] uppercase shrink-0" style="color: var(--text-muted);">
                  kit
                </dt>
                <dd class="mono text-right text-[0.7rem]" style="color: var(--text);">
                  {tier.kit}
                </dd>
              </div>
            </dl>

            {tier.extra && (
              <div
                class="mt-1 border-l-2 pl-3 text-[0.7rem] leading-relaxed"
                style={`border-color: ${tier.tagColor}; color: var(--text-dim);`}
              >
                <span class="mono uppercase tracking-[0.15em]" style={`color: ${tier.tagColor};`}>★ exclusivo · </span>
                {tier.extra}
              </div>
            )}

            <button
              type="button"
              disabled
              class="mt-auto cursor-not-allowed border py-2.5 mono text-[0.7rem] font-bold tracking-[0.25em] uppercase opacity-70"
              style={
                tier.featured
                  ? `background: ${tier.tagColor}; border-color: ${tier.tagColor}; color: var(--btn-icon-bg);`
                  : "background: color-mix(in srgb, var(--accent) 10%, transparent); border-color: var(--border); color: var(--text-dim);"
              }
            >
              em breve
            </button>
          </article>
        ))
      }
    </div>

    <div class="mx-auto mt-12 max-w-2xl text-center">
      <div
        class="mx-auto mb-4 h-px w-12"
        style="background: var(--border);"
      />
      <p class="mono text-[0.7rem] leading-relaxed tracking-[0.05em]" style="color: var(--text-muted);">
        Tiers acumulam conveniências (heal, fly, repair, queue prioritária),
        kits, multiplicadores em XP/economia e cosméticos.
        <br class="hidden md:block" />
        Aura Estelar é exclusiva do tier <span style="color: var(--text-dim);">Astro</span>.
        <span class="block mt-2">
          Tiers paralelos — <span style="color: var(--text-dim);">Influencer</span>,
          <span style="color: var(--text-dim);"> Booster</span>,
          <span style="color: var(--text-dim);"> Membro Vinculado</span> — são concedidos, não vendidos.
        </span>
      </p>
    </div>
  </div>
</section>
