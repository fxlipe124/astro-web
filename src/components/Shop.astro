---
import Block from "./Block.astro";

interface Props {
  theme: "saturated" | "moody";
}

const themes = {
  saturated: {
    bg: "#0B0F22",
    bgAlt: "#141A38",
    card: "rgba(20, 26, 56, 0.5)",
    cardFeatured: "rgba(31, 39, 80, 0.7)",
    border: "rgba(255, 255, 255, 0.10)",
    accent: "#6FE89C",
    text: "#FFFFFF",
    textDim: "rgba(255, 255, 255, 0.7)",
    textMuted: "rgba(255, 255, 255, 0.5)",
    btnBg: "rgba(111, 232, 156, 0.10)",
    btnBgFeatured: "#6FE89C",
    btnBorder: "rgba(255, 255, 255, 0.15)",
    btnText: "rgba(255, 255, 255, 0.7)",
    btnTextFeatured: "#0B0F22",
  },
  moody: {
    bg: "#07090F",
    bgAlt: "#0F1320",
    card: "rgba(19, 24, 38, 0.5)",
    cardFeatured: "rgba(31, 37, 53, 0.7)",
    border: "#28304A",
    accent: "#E8B95C",
    text: "#F2EBD8",
    textDim: "#9A8E70",
    textMuted: "#5C5340",
    btnBg: "rgba(232, 185, 92, 0.10)",
    btnBgFeatured: "#E8B95C",
    btnBorder: "#28304A",
    btnText: "#9A8E70",
    btnTextFeatured: "#07090F",
  },
};

const { theme } = Astro.props;
const t = themes[theme];

// Tiers reais — extraídos de docs/decisoes-de-produto.md §1 e
// skripts/skyblock/luckperms-hierarchy.sk. Cores espelham os prefixos
// LuckPerms (ex: Nova &a verde, Hyper &4 vermelho, Astro &d rosa bold).
const tiers = [
  {
    n: "1",
    name: "Nova",
    block: "emerald" as const,
    tagColor: "#55FF55",
    tag: "[NOVA]",
    blurb: "Primeiro tier de apoio.",
    cmds: ["/heal"],
    homes: 3,
    kit: "kit_nova · 12h",
  },
  {
    n: "2",
    name: "Nova+",
    block: "emerald" as const,
    tagColor: "#55FF55",
    tag: "[NOVA+]",
    blurb: "Nova com fome cheia.",
    cmds: ["/heal", "/feed"],
    homes: 4,
    kit: "kit_novaplus · 8h",
  },
  {
    n: "3",
    name: "Hyper",
    block: "redstone" as const,
    tagColor: "#FF5555",
    tag: "[HYPER]",
    blurb: "Reparo direto na bancada.",
    cmds: ["/heal", "/feed", "/repair"],
    homes: 5,
    kit: "kit_hyper · 6h",
  },
  {
    n: "4",
    name: "Hyper+",
    block: "redstone" as const,
    tagColor: "#FF5555",
    tag: "[HYPER+]",
    blurb: "Decola na sua ilha.",
    cmds: ["/heal", "/feed", "/repair", "/fly"],
    homes: 6,
    kit: "kit_hyperplus · 4h",
  },
  {
    n: "5",
    name: "Apex",
    block: "diamond" as const,
    tagColor: "#FFFFFF",
    tag: "[APEX]",
    blurb: "Workshop e ender-chest portáteis.",
    cmds: ["+ /workbench", "+ /enderchest", "+ /near"],
    homes: 8,
    kit: "kit_apex · 2h",
  },
  {
    n: "6",
    name: "Astro",
    block: "amethyst" as const,
    tagColor: "#FF55FF",
    tag: "[ASTRO]",
    blurb: "Top donor. Mesmo nome do servidor.",
    cmds: ["+ /more", "+ /book", "+ /invsee"],
    homes: 10,
    kit: "kit_astro · 1h",
    featured: true,
    extra: "Aura Estelar exclusiva — efeito de partículas + farm AFK ligado por /aura.",
  },
];
---

<section
  id="loja"
  class="relative scroll-mt-20 px-6 py-20 md:px-10 md:py-28"
  style={`background: ${t.bgAlt};`}
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <div
          class="mono text-xs font-semibold tracking-[0.25em] uppercase"
          style={`color: ${t.accent};`}
        >
          ▸ loja
        </div>
        <h2
          class="display mt-3 text-4xl font-extrabold md:text-5xl"
          style={`color: ${t.text};`}
        >
          Seis tiers de apoio.
        </h2>
      </div>
      <p class="mono max-w-md text-sm" style={`color: ${t.textDim};`}>
        Tiers aceleram progressão e adicionam conveniências. Comprar não é obrigatório — o jogo flui sem eles, mas ajuda quem ajuda.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        tiers.map((tier) => (
          <article
            class:list={[
              "group relative flex flex-col gap-4 border p-6 transition-all duration-300 hover:-translate-y-1",
              tier.featured ? "lg:scale-[1.03]" : "",
            ]}
            style={`background: ${tier.featured ? t.cardFeatured : t.card}; border-color: ${tier.featured ? tier.tagColor + "66" : t.border}; ${tier.featured ? `box-shadow: 0 12px 40px -8px ${tier.tagColor}55;` : ""}`}
          >
            {tier.featured && (
              <span
                class="absolute -top-3 left-1/2 -translate-x-1/2 mono px-3 py-0.5 text-[0.6rem] font-bold tracking-[0.25em] uppercase"
                style={`background: ${t.bgAlt}; color: ${tier.tagColor};`}
              >
                ✦ top donor
              </span>
            )}

            <header class="flex items-center justify-between">
              <span
                class="mono text-[0.6rem] font-bold tracking-[0.25em] uppercase"
                style={`color: ${t.textMuted};`}
              >
                tier 0{tier.n}
              </span>
              <span
                class="mono inline-block px-2 py-0.5 text-[0.6rem] font-bold tracking-[0.15em]"
                style={`background: ${tier.tagColor}22; color: ${tier.tagColor}; border: 1px solid ${tier.tagColor}55;`}
              >
                {tier.tag}
              </span>
            </header>

            <div class="flex items-center gap-3">
              <div class="shrink-0 transition-transform duration-500 group-hover:-translate-y-1 group-hover:rotate-3">
                <Block palette={tier.block} size={48} />
              </div>
              <div>
                <h3
                  class="display text-xl font-extrabold leading-tight md:text-2xl"
                  style={`color: ${t.text};`}
                >
                  {tier.name}
                </h3>
                <p class="mt-0.5 text-xs" style={`color: ${t.textDim};`}>
                  {tier.blurb}
                </p>
              </div>
            </div>

            <div class="h-px" style={`background: ${t.border};`} />

            <dl class="space-y-2.5 text-sm" style={`color: ${t.textDim};`}>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="mono text-[0.6rem] tracking-[0.2em] uppercase shrink-0" style={`color: ${t.textMuted};`}>
                  comandos
                </dt>
                <dd class="mono text-right text-[0.7rem]" style={`color: ${t.text};`}>
                  {tier.cmds.join(" ")}
                </dd>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="mono text-[0.6rem] tracking-[0.2em] uppercase shrink-0" style={`color: ${t.textMuted};`}>
                  /sethome
                </dt>
                <dd class="mono text-right text-[0.7rem]" style={`color: ${t.text};`}>
                  {tier.homes} slots
                </dd>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <dt class="mono text-[0.6rem] tracking-[0.2em] uppercase shrink-0" style={`color: ${t.textMuted};`}>
                  kit
                </dt>
                <dd class="mono text-right text-[0.7rem]" style={`color: ${t.text};`}>
                  {tier.kit}
                </dd>
              </div>
            </dl>

            {tier.extra && (
              <div
                class="mt-1 border-l-2 pl-3 text-[0.7rem] leading-relaxed"
                style={`border-color: ${tier.tagColor}; color: ${t.textDim};`}
              >
                <span class="mono uppercase tracking-[0.15em]" style={`color: ${tier.tagColor};`}>★ exclusivo · </span>
                {tier.extra}
              </div>
            )}

            <button
              type="button"
              disabled
              class="mt-auto cursor-not-allowed border py-2.5 mono text-[0.7rem] font-bold tracking-[0.25em] uppercase transition-colors"
              style={`background: ${tier.featured ? t.btnBgFeatured : t.btnBg}; border-color: ${tier.featured ? t.btnBgFeatured : t.btnBorder}; color: ${tier.featured ? t.btnTextFeatured : t.btnText}; opacity: 0.7;`}
            >
              em breve
            </button>
          </article>
        ))
      }
    </div>

    <div class="mx-auto mt-12 max-w-2xl text-center">
      <div
        class="mx-auto mb-4 h-px w-12"
        style={`background: ${t.border};`}
      />
      <p class="mono text-[0.7rem] leading-relaxed tracking-[0.05em]" style={`color: ${t.textMuted};`}>
        Tiers acumulam conveniências (heal, fly, repair, queue prioritária),
        kits, multiplicadores em XP/economia e cosméticos.
        <br class="hidden md:block" />
        Aura Estelar é exclusiva do tier <span style={`color: ${t.textDim};`}>Astro</span>.
        <span class="block mt-2">
          Tiers paralelos — <span style={`color: ${t.textDim};`}>Influencer</span>,
          <span style={`color: ${t.textDim};`}> Booster</span>,
          <span style={`color: ${t.textDim};`}> Membro Vinculado</span> — são concedidos, não vendidos.
        </span>
      </p>
    </div>
  </div>
</section>
