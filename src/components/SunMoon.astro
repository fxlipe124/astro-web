---
// Sol (light) e Lua (dark) que se trocam no hero quando o tema muda.
// Posicionamento absolute herdado da classe .celestial (em base.css).
// Animação: sol cai e lua sobe (vice-versa) via translateY + opacity.
//
// Ambos usam o MESMO viewBox 100x100 e mesma escala do corpo (16x16 pixels
// renderizados a 3.5 cada = 56px centered). Garante que o disco do sol e
// da lua tenham o mesmo tamanho visual; sol ganha raios extra como
// diferencial.

interface Props {
  size?: number;
}

const { size = 120 } = Astro.props;

// Helper: gera células de uma esfera pixelada (corpo do disco).
// Retorna array de { x, y, shade } em coords do viewBox 100x100.
function buildSphereCells(palette: { light: string; mid: string; dark: string; deep: string; edge: string; crater?: string }, craters: Array<{ x: number; y: number; r: number }> = []) {
  const grid = 16;
  const cx = (grid - 1) / 2;
  const cy = (grid - 1) / 2;
  const r = grid / 2 - 0.3;
  const renderScale = 3.5;
  const startX = (100 - grid * renderScale) / 2;
  const startY = (100 - grid * renderScale) / 2;
  const cells = [];
  for (let y = 0; y < grid; y++) {
    for (let x = 0; x < grid; x++) {
      const dx = x - cx;
      const dy = y - cy;
      const d = Math.sqrt(dx * dx + dy * dy);
      if (d > r) continue;
      let isCrater = false;
      for (const cr of craters) {
        const cdx = dx - cr.x;
        const cdy = dy - cr.y;
        if (Math.sqrt(cdx * cdx + cdy * cdy) < cr.r) {
          isCrater = true;
          break;
        }
      }
      const shade = -(dx + 1) / r - (dy + 1) / r + d / r;
      let color;
      if (isCrater) color = palette.crater ?? palette.deep;
      else if (d > r - 0.5) color = palette.edge;
      else if (shade < -0.7) color = palette.light;
      else if (shade < -0.1) color = palette.mid;
      else if (shade < 0.6) color = palette.dark;
      else color = palette.deep;
      cells.push({
        x: startX + x * renderScale,
        y: startY + y * renderScale,
        color,
      });
    }
  }
  return cells;
}

const moonCells = buildSphereCells(
  {
    light: "#F4D67A",
    mid: "#E8B95C",
    dark: "#B8862E",
    deep: "#7E5A1A",
    edge: "#7E5A1A",
    crater: "#7E5A1A",
  },
  [
    { x: -2, y: -3, r: 1.0 },
    { x: 3, y: -1, r: 0.9 },
    { x: -1, y: 2, r: 0.7 },
    { x: 1, y: 4, r: 0.7 },
    { x: 4, y: 3, r: 0.6 },
    { x: -4, y: 0, r: 0.5 },
  ]
);

const sunCells = buildSphereCells({
  light: "#FFE08A",
  mid: "#FFD43B",
  dark: "#F4A028",
  deep: "#D67510",
  edge: "#B85A0E",
});
---

<!-- LUA — dourada, com crateras pixel-art -->
<div
  class="celestial celestial-moon"
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 100 100"
    width={size}
    height={size}
    shape-rendering="crispEdges"
    style={`filter: drop-shadow(0 0 ${size * 0.18}px rgba(232, 185, 92, 0.55));`}
  >
    {/* Corpo da lua — mesma escala/posição do sol */}
    {moonCells.map((c) => (
      <rect x={c.x} y={c.y} width={3.5} height={3.5} fill={c.color} />
    ))}
  </svg>
</div>

<!-- SOL — radiante com raios -->
<div
  class="celestial celestial-sun"
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 100 100"
    width={size}
    height={size}
    shape-rendering="crispEdges"
    style={`filter: drop-shadow(0 0 ${size * 0.18}px rgba(255, 200, 80, 0.7));`}
  >
    {/* Raios solares (8 direções) — diferenciador visual */}
    <g stroke="#FFD43B" stroke-width="3" stroke-linecap="round" opacity="0.85">
      <line x1="50" y1="6" x2="50" y2="18" />
      <line x1="50" y1="82" x2="50" y2="94" />
      <line x1="6" y1="50" x2="18" y2="50" />
      <line x1="82" y1="50" x2="94" y2="50" />
      <line x1="18" y1="18" x2="26" y2="26" />
      <line x1="74" y1="74" x2="82" y2="82" />
      <line x1="82" y1="18" x2="74" y2="26" />
      <line x1="18" y1="82" x2="26" y2="74" />
    </g>

    {/* Corpo do sol — mesma escala/posição da lua */}
    {sunCells.map((c) => (
      <rect x={c.x} y={c.y} width={3.5} height={3.5} fill={c.color} />
    ))}
  </svg>
</div>
