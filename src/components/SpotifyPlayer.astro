---
// Barra fixa superior — Spotify embed compact (80px) ocupando largura total.
// Minimalista, sempre visível. Volume não é controlável (limitação do embed
// oficial — confirmado em https://developer.spotify.com/documentation/embeds).

interface Props {
  playlistId?: string;
}

const { playlistId = "0BEJAMq4yvYzw4W6mK9zOH" } = Astro.props;
const embedSrc = `https://open.spotify.com/embed/playlist/${playlistId}?utm_source=generator&theme=0`;
---

<div class="spotify-bar" aria-label="Player de música do servidor">
  <iframe
    data-testid="embed-iframe"
    src={embedSrc}
    width="100%"
    height="80"
    frameborder="0"
    allowfullscreen
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"
    title="Player de música Spotify — trilha do servidor"
    style="display: block; border: 0;"
  ></iframe>
</div>

<style>
  .spotify-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    z-index: 50;
    box-shadow: 0 1px 0 0 var(--border), 0 4px 16px -4px rgba(0, 0, 0, 0.4);
  }

  /* Hide on print */
  @media print {
    .spotify-bar {
      display: none;
    }
  }
</style>
