// =========================================================================
// SAND — 20 wide × 26 tall. Sand island with cactus.
// =========================================================================
const sand = [
  "....................",
  "........p...........",
  ".......pXp..........",
  ".......XXX..........",
  ".......pXp..........",
  ".......XXX..........",
  ".......pXp..........",
  ".......XXX..........",
  ".......pXp..........",
  ".......XXX..........",
  "...SSSSXSSSSSS......",
  "...SssSXSssSsS......",
  "...sSSSsSSsSsS......",
  "....sSsSsSsSs.......",
  ".....SsSsSsSS.......",
  "......sSsSsS........",
  ".......SsSs.........",
  "........sS..........",
  ".........s..........",
  "....................",
  "....................",
  "....................",
  "....................",
  "....................",
  "....................",
  "....................",
];

const variants = { mini, compact, "classic-l": classicL, sand };
const grid = variants[variant];

const cols = Math.max(...grid.map((r) => r.length));
const rows = grid.length;

// flatten to pixels
const pixels: { x: number; y: number; c: string }[] = [];
for (let y = 0; y < rows; y++) {
  const row = grid[y];
  for (let x = 0; x < row.length; x++) {
    const ch = row[x];
    if (ch === "." || !palette[ch]) continue;
    pixels.push({ x, y, c: palette[ch] });
  }
}
---

<svg
  viewBox={`0 0 ${cols} ${rows}`}
  width={size}
  height={size * (rows / cols)}
  shape-rendering="crispEdges"
  class:list={["sprite-island", className]}
  aria-hidden="true"
>
  {pixels.map((p) => <rect x={p.x} y={p.y} width="1" height="1" fill={p.c} />)}
</svg>
