---
// Player minimalista próprio + iframe SoundCloud escondido controlado via
// SoundCloud Widget API (developers.soundcloud.com/docs/api/html5-widget).
//
// UI: barra fina 40px no topo com label da track + slider de volume +
// botão play/pause. Iframe SoundCloud fica fora de tela (w/h 0).
// Volume default 30% setado no evento READY.

interface Props {
  playlistUrl?: string;
  playlistArtworkUrl?: string;
  defaultVolume?: number;
  trackCount?: number;
}

const {
  playlistUrl = "https://soundcloud.com/fxlipe12/sets/mine-vibes",
  // Artwork da playlist no CDN do SoundCloud (variante t67x67 = crisp
  // em retina pro display de 24px). Obtida via oEmbed:
  //   https://soundcloud.com/oembed?url=<playlistUrl>&format=json
  // Atualizar manualmente se a capa mudar.
  playlistArtworkUrl = "https://i1.sndcdn.com/artworks-Zr9rBgynWyzDvlFp-dIkwqA-t67x67.jpg",
  defaultVolume = 30,
  // Aproximado — só pro Math.random() escolher um start_track. Se a
  // playlist crescer, atualizar aqui. SoundCloud trata índices fora
  // do range como wrap/clamp.
  trackCount = 120,
} = Astro.props;

const widgetParams = "auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&show_teaser=false&visual=false";
---

<div
  class="sc-bar fixed top-0 left-0 right-0 z-50 flex items-center gap-3 border-b px-4 backdrop-blur-md"
  style="height: 40px; background: color-mix(in srgb, var(--bg-base) 80%, transparent); border-color: var(--border);"
  aria-label="Trilha sonora do servidor"
>
  {/* Artwork da playlist é src default (carrega instant). SVG fica atrás
       como fallback caso o img falhe (onerror baixa opacity). Quando uma
       track tem artwork própria, JS substitui o src. Wrap em <a> pra a
       artwork também levar pro link da track (igual o label faz). */}
  <a
    data-sc-artwork-link
    href={playlistUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Abrir track no SoundCloud"
    class="relative h-6 w-6 shrink-0 transition-opacity hover:opacity-70"
  >
    <svg
      class="absolute inset-0 h-full w-full"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
      style="color: var(--accent);"
    >
      <path d="M6 8 L6 16" />
      <path d="M9 5 L9 19" />
      <path d="M12 9 L12 15" />
      <path d="M15 6 L15 18" />
      <path d="M18 10 L18 14" />
    </svg>
    <img
      data-sc-artwork
      alt=""
      src={playlistArtworkUrl}
      width="24"
      height="24"
      class="absolute inset-0 h-full w-full rounded-sm object-cover"
      style="background: var(--border);"
      onerror="this.style.opacity='0'"
    />
  </a>

  {/* Label clicável — abre a track atual no SoundCloud em nova aba.
       Default href = playlist; JS atualiza pro permalink da track no READY. */}
  <a
    href={playlistUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="mono shrink-0 truncate text-[0.65rem] font-medium tracking-[0.15em] uppercase transition-opacity hover:opacity-70"
    style="color: var(--text-dim); max-width: 40vw;"
    data-sc-label
  >
    mine vibes · pausado
  </a>

  {/* Spacer */}
  <div class="flex-1"></div>

  {/* Volume control (collapsed em mobile) */}
  <div class="hidden items-center gap-2 sm:flex">
    <svg class="h-3 w-3 shrink-0" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" style="color: var(--text-muted);">
      <path d="M7 3 L4 6 L1 6 L1 10 L4 10 L7 13 Z" />
      <path d="M10 6 Q12 8 10 10" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round" />
    </svg>
    <input
      type="range"
      min="0"
      max="100"
      value={defaultVolume}
      data-sc-volume
      class="sc-volume-slider h-1 w-20 cursor-pointer"
      aria-label="Volume da trilha sonora"
    />
  </div>

  {/* Play/Pause toggle */}
  <button
    type="button"
    data-sc-toggle
    aria-label="Tocar trilha sonora"
    class="inline-flex h-6 w-6 shrink-0 items-center justify-center transition-opacity hover:opacity-70 disabled:cursor-wait disabled:opacity-40"
    style="color: var(--text);"
    disabled
  >
    <svg class="icon-play h-3 w-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <path d="M3 2 L13 8 L3 14 Z" />
    </svg>
    <svg class="icon-pause h-3 w-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" style="display: none;">
      <rect x="3" y="2" width="3.5" height="12" />
      <rect x="9.5" y="2" width="3.5" height="12" />
    </svg>
  </button>

  {/* Skip — próxima track */}
  <button
    type="button"
    data-sc-next
    aria-label="Próxima track"
    class="inline-flex h-6 w-6 shrink-0 items-center justify-center transition-opacity hover:opacity-70 disabled:cursor-wait disabled:opacity-40"
    style="color: var(--text);"
    disabled
  >
    <svg class="h-3 w-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <path d="M3 2 L11 8 L3 14 Z" />
      <rect x="12" y="2" width="2" height="12" />
    </svg>
  </button>

  {/* Progress bar — linha fina embaixo */}
  <div
    class="pointer-events-none absolute bottom-0 left-0 right-0 h-px"
    style="background: var(--border);"
  >
    <div
      class="h-full transition-[width] duration-200 ease-linear"
      style="background: var(--accent); width: 0%;"
      data-sc-progress
    ></div>
  </div>

  {/* iframe escondido — Widget API controla. src é setada via JS abaixo
       com start_track random pra carregar direto numa track aleatória. */}
  <iframe
    id="sc-widget"
    width="0"
    height="0"
    frameborder="0"
    allow="autoplay"
    title="SoundCloud widget"
    style="position: absolute; width: 0; height: 0; border: 0; pointer-events: none; clip: rect(0 0 0 0);"
    data-default-volume={defaultVolume}
    data-playlist-url={playlistUrl}
    data-track-count={trackCount}
    data-widget-params={widgetParams}
  ></iframe>
</div>

<style>
  /* Slider customizado pra combinar com o tema */
  .sc-volume-slider {
    -webkit-appearance: none;
    appearance: none;
    background: var(--border);
    border-radius: 1px;
    outline: none;
  }
  .sc-volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 0;
  }
  .sc-volume-slider::-moz-range-thumb {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 0;
  }
</style>

{/* Inline script: define iframe.src com start_track random IMEDIATAMENTE
    (antes mesmo do script da Widget API carregar). O iframe começa o
    fetch da track random direto — elimina round-trip de getSounds + skip. */}
<script is:inline>
  (function () {
    var iframe = document.getElementById("sc-widget");
    if (!iframe || iframe.src) return;
    var url = iframe.dataset.playlistUrl;
    var count = parseInt(iframe.dataset.trackCount || "1", 10);
    var params = iframe.dataset.widgetParams || "";
    var startTrack = Math.floor(Math.random() * count);
    iframe.src =
      "https://w.soundcloud.com/player/?url=" +
      encodeURIComponent(url) +
      "&" +
      params +
      "&start_track=" +
      startTrack;
  })();
</script>

<script is:inline src="https://w.soundcloud.com/player/api.js" async></script>

<script>
  // SoundCloud Widget API
  // Doc: developers.soundcloud.com/docs/api/html5-widget
  type SCWidget = {
    bind: (event: string, cb: (e?: any) => void) => void;
    play: () => void;
    pause: () => void;
    toggle: () => void;
    next: () => void;
    prev: () => void;
    skip: (index: number) => void;
    setVolume: (vol: number) => void;
    getVolume: (cb: (vol: number) => void) => void;
    getCurrentSound: (cb: (sound: any) => void) => void;
    getSounds: (cb: (sounds: any[]) => void) => void;
  };

  let widget: SCWidget | null = null;
  let isPaused = true;
  // Debounce do botão next — clicks dentro de 500ms são ignorados.
  // Cobre double-click acidental + caso o handler tenha sido bound 2x
  // (ex: DOMContentLoaded + astro:page-load disparando tryInit).
  let lastNextAt = 0;
  // Quanto auto-skip ainda podemos fazer pra fugir de tracks SNIP/BLOCK.
  // Limite por sessão pra não entrar em loop se a playlist for ruim.
  let autoSkipBudget = 30;
  // Posição relativa atual da playback (0..1) — atualizada em PLAY_PROGRESS.
  // Usada pra detectar cutoff: se PAUSE dispara não-iniciado-pelo-usuário
  // com position < 0.95, a track foi cortada (SNIP que escapou da detecção).
  let lastRelativePosition = 0;
  let userClickedPause = false;

  // Track é só preview / não-tocável? SoundCloud marca tracks que exigem
  // SoundCloud Go+ como policy: "SNIP" / "MONETIZE" (só 30s tocam).
  // Belt-and-suspenders: se duration é claramente menor que full_duration,
  // é snippet independente do campo policy.
  function shouldAutoSkip(sound: any): boolean {
    if (!sound) return false;
    if (sound.policy === "SNIP" || sound.policy === "BLOCK" || sound.policy === "MONETIZE") return true;
    if (sound.playable === false || sound.streamable === false) return true;
    if (typeof sound.duration === "number" && typeof sound.full_duration === "number") {
      // Threshold de 90%: tracks legit às vezes têm pequena diferença
      // (intro/outro), então não usamos igualdade exata. Importante:
      // só checa se duration > 0 — duration 0 acontece DURANTE loading,
      // não é sinal de snippet.
      if (sound.duration > 0 && sound.full_duration > 0 && sound.duration < sound.full_duration * 0.9) return true;
    }
    return false;
  }

  function setLabel(text: string) {
    const el = document.querySelector<HTMLElement>("[data-sc-label]");
    if (el) el.textContent = text;
  }

  function setArtwork(url: string | null | undefined) {
    const img = document.querySelector<HTMLImageElement>("[data-sc-artwork]");
    if (!img || !url) return;
    // SoundCloud serve artwork em vários tamanhos: -large, -t500x500,
    // -t300x300, -t67x67, etc. Sempre pedimos t67x67 (crisp em 24px @2x).
    const sized = url.replace(/-(large|t\d+x\d+)\.(jpg|png)/, "-t67x67.$2");
    if (img.src !== sized) img.src = sized;
  }

  function setLink(url: string | null | undefined) {
    if (!url) return;
    const labelAnchor = document.querySelector<HTMLAnchorElement>("[data-sc-label]");
    const artworkAnchor = document.querySelector<HTMLAnchorElement>("[data-sc-artwork-link]");
    if (labelAnchor) labelAnchor.href = url;
    if (artworkAnchor) artworkAnchor.href = url;
  }

  // Decodifica entities HTML (ex: "&amp;" → "&"). SoundCloud às vezes
  // retorna title com entities literais enquanto publisher_metadata.artist
  // vem decodificado — sem isso, includes() falha e o label duplica.
  function decodeEntities(s: string): string {
    const ta = document.createElement("textarea");
    ta.innerHTML = s;
    return ta.value;
  }

  // Monta o label "artista — título · status".
  // Prioridade pro artista:
  //   1. publisher_metadata.artist — canonical, vem populado em tracks
  //      oficiais (Alan Walker, Skrillex, etc.).
  //   2. user.username — fallback APENAS quando o título não segue o padrão
  //      "Artist - Title" (heurística: tem ' - '). Pra titles curtos sem
  //      dash (ex: "4U"), o uploader é a única pista. Pra titles com dash,
  //      o artista já tá embutido no título e fallback ia poluir (ex:
  //      uploader 'Larauder' não deveria ser prependado em 'KDrew - Circles').
  // Em qualquer caso, se o title já contém o nome (normalizado), pula a
  // duplicação.
  function buildLabel(sound: any, status: "pausado" | "tocando"): string {
    const titleRaw = sound?.title?.toString().trim();
    if (!titleRaw) return `trilha sonora · ${status}`;
    const title = decodeEntities(titleRaw).toLowerCase();
    const canonicalArtist = sound?.publisher_metadata?.artist?.toString().trim();
    const titleHasArtistDash = / - /.test(titleRaw);
    const fallbackArtist = !titleHasArtistDash
      ? sound?.user?.username?.toString().trim()
      : null;
    const artistRaw = canonicalArtist || fallbackArtist;
    if (!artistRaw) return `${title} · ${status}`;
    const artist = decodeEntities(artistRaw).toLowerCase();
    // Normaliza só pra comparação (display preserva original): strip
    // pontuação/espaços. Cobre 'jr gong' vs 'jr. gong', 'A.S.A.P.' vs 'asap'.
    const normalize = (s: string) => s.replace(/[^\p{L}\p{N}]+/gu, "");
    const stripThe = (s: string) => s.replace(/^the\s+/, "");
    const normTitle = normalize(title);
    if (normTitle.includes(normalize(artist)) || normTitle.includes(normalize(stripThe(artist)))) {
      return `${title} · ${status}`;
    }
    return `${artist} — ${title} · ${status}`;
  }

  function setIconPaused(paused: boolean) {
    const toggle = document.querySelector<HTMLButtonElement>("[data-sc-toggle]");
    const playIcon = document.querySelector<HTMLElement>("[data-sc-toggle] .icon-play");
    const pauseIcon = document.querySelector<HTMLElement>("[data-sc-toggle] .icon-pause");
    if (!toggle || !playIcon || !pauseIcon) return;
    playIcon.style.display = paused ? "block" : "none";
    pauseIcon.style.display = paused ? "none" : "block";
    toggle.setAttribute("aria-label", paused ? "Tocar trilha sonora" : "Pausar trilha sonora");
  }

  function setProgress(pct: number) {
    const bar = document.querySelector<HTMLElement>("[data-sc-progress]");
    if (bar) bar.style.width = `${Math.min(100, Math.max(0, pct))}%`;
  }

  function setupWidget() {
    const iframe = document.getElementById("sc-widget") as HTMLIFrameElement | null;
    const SC = (window as any).SC;
    if (!iframe || !SC?.Widget) return false;

    widget = SC.Widget(iframe);
    if (!widget) return false;

    const defaultVolume = parseInt(iframe.dataset.defaultVolume ?? "30", 10);

    widget.bind(SC.Widget.Events.READY, () => {
      // Volume padrão 30%
      widget!.setVolume(defaultVolume);

      // Habilita botões imediatamente
      const toggle = document.querySelector<HTMLButtonElement>("[data-sc-toggle]");
      if (toggle) toggle.disabled = false;
      const next = document.querySelector<HTMLButtonElement>("[data-sc-next]");
      if (next) next.disabled = false;

      // READY dispara antes do widget ter resolvido a track do start_track —
      // getCurrentSound retorna sound parcial/null no primeiro tick. Retry
      // até a track ter title+artwork (ou 5 tentativas, ~2.5s).
      //
      // Sobre auto-skip no play: se a track random do start_track for
      // unplayable (DMCA / region / deletada), o SoundCloud auto-pula até
      // achar uma tocável. Tentei pre-skip aqui via getCurrentSound +
      // widget.next(), mas (a) getCurrentSound retorna null nas primeiras
      // chamadas e o loop infinito quebra o load, (b) skipping ANTES do
      // ready resolver completamente coloca o widget em estado inconsistente.
      // Decisão: aceitar a quirk da plataforma — raro o suficiente.
      const tryFetchSound = (attempts: number) => {
        widget!.getCurrentSound((sound: any) => {
          if (sound?.title && sound?.artwork_url) {
            // Track random pego pelo start_track caiu numa SNIP/BLOCK?
            // Pula proativamente — LOAD_PROGRESS pega o próximo.
            if (shouldAutoSkip(sound) && autoSkipBudget > 0) {
              autoSkipBudget -= 1;
              widget!.next();
              return;
            }
            setLabel(buildLabel(sound, "pausado"));
            setArtwork(sound.artwork_url);
            setLink(sound.permalink_url);
          } else if (attempts > 0) {
            setTimeout(() => tryFetchSound(attempts - 1), 500);
          } else if (sound?.title) {
            setLabel(buildLabel(sound, "pausado"));
            setLink(sound.permalink_url);
          }
        });
      };
      tryFetchSound(5);
    });

    // Updates de label/artwork/link consolidados num único scheduler:
    // - Mesma track (mudou só estado play/pause) → atualiza imediato
    // - Track diferente (LOAD_PROGRESS / SoundCloud auto-skip) → debounce 1200ms
    //
    // Motivação: quando uma track é unplayable (DMCA / region-blocked / deletada),
    // SoundCloud auto-pula até achar uma tocável. Sem debounce, UI flickera
    // entre as 2-3 tracks intermediárias. Com debounce, usuário vê só a track
    // final (a que vai realmente tocar).
    let lastTrackId: number | null = null;
    let labelUpdateTimer: number | null = null;
    function scheduleLabelUpdate(immediate: boolean) {
      if (labelUpdateTimer !== null) window.clearTimeout(labelUpdateTimer);
      const runUpdate = () => {
        if (!widget) return;
        widget.getCurrentSound((s: any) => {
          if (!s?.id) return;
          lastTrackId = s.id;
          setLabel(buildLabel(s, isPaused ? "pausado" : "tocando"));
          setArtwork(s.artwork_url);
          setLink(s.permalink_url);
        });
      };
      if (immediate) runUpdate();
      else labelUpdateTimer = window.setTimeout(runUpdate, 1200);
    }

    widget.bind(SC.Widget.Events.LOAD_PROGRESS, () => {
      widget!.getCurrentSound((sound: any) => {
        if (sound?.id && sound.id !== lastTrackId) {
          // Auto-skip tracks só-preview (policy: SNIP — exigem SoundCloud
          // Go+ pra tocar completo). Sem isso, a track toca 30s e o widget
          // pára. Skip antes do label atualizar pra UI ir direto pra
          // próxima tocável.
          if (shouldAutoSkip(sound) && autoSkipBudget > 0) {
            autoSkipBudget -= 1;
            // Marca como visto pra não tentar de novo na próxima volta
            lastTrackId = sound.id;
            widget!.next();
            return;
          }
          scheduleLabelUpdate(false);
        }
      });
    });

    widget.bind(SC.Widget.Events.PLAY, () => {
      isPaused = false;
      setIconPaused(false);
      widget!.getCurrentSound((sound: any) => {
        // Defesa em profundidade: se PLAY disparou numa track SNIP que escapou
        // do LOAD_PROGRESS (timing), pula imediato. Usuário ouve um instante
        // de áudio mas evita os 30s + parada.
        if (shouldAutoSkip(sound) && autoSkipBudget > 0) {
          autoSkipBudget -= 1;
          widget!.next();
          return;
        }
        scheduleLabelUpdate(sound?.id === lastTrackId);
      });
    });

    widget.bind(SC.Widget.Events.PAUSE, () => {
      isPaused = true;
      setIconPaused(true);

      // Cutoff detection: se PAUSE veio sem o usuário ter clicado pause E
      // a posição estava < 95%, a track foi cortada (SNIP que escapou da
      // detecção via policy/duration, ou cutoff regional). Auto-skip pra
      // próxima e dá play.
      const wasUserPause = userClickedPause;
      userClickedPause = false;
      if (!wasUserPause && lastRelativePosition > 0 && lastRelativePosition < 0.95 && autoSkipBudget > 0) {
        autoSkipBudget -= 1;
        widget!.next();
        setTimeout(() => widget?.play(), 500);
        return;
      }

      widget!.getCurrentSound((sound: any) => {
        scheduleLabelUpdate(sound?.id === lastTrackId);
      });
    });

    widget.bind(SC.Widget.Events.PLAY_PROGRESS, (e: any) => {
      if (typeof e?.relativePosition === "number") {
        lastRelativePosition = e.relativePosition;
        setProgress(e.relativePosition * 100);
      }
    });

    widget.bind(SC.Widget.Events.FINISH, () => {
      // Track terminou — reseta tracking de posição pra próxima.
      lastRelativePosition = 0;
      setProgress(0);
    });

    // Bind toggle button — marca userClickedPause quando user pausa,
    // pra distinguir pause-do-usuário de cutoff-automático no PAUSE handler.
    const toggle = document.querySelector<HTMLButtonElement>("[data-sc-toggle]");
    if (toggle && toggle.dataset.bound !== "1") {
      toggle.dataset.bound = "1";
      toggle.addEventListener("click", () => {
        if (!isPaused) userClickedPause = true;
        widget?.toggle();
      });
    }

    // Bind next button (com debounce)
    const nextBtn = document.querySelector<HTMLButtonElement>("[data-sc-next]");
    if (nextBtn && nextBtn.dataset.bound !== "1") {
      nextBtn.dataset.bound = "1";
      nextBtn.addEventListener("click", () => {
        const now = Date.now();
        if (now - lastNextAt < 500) return;
        lastNextAt = now;
        widget?.next();
      });
    }

    // Bind volume slider
    const slider = document.querySelector<HTMLInputElement>("[data-sc-volume]");
    if (slider && slider.dataset.bound !== "1") {
      slider.dataset.bound = "1";
      slider.addEventListener("input", () => {
        const vol = parseInt(slider.value, 10);
        widget?.setVolume(vol);
      });
    }

    return true;
  }

  // SoundCloud lib carrega async — pode estar pronto ou não no DOMContentLoaded
  function tryInit() {
    if (!setupWidget()) {
      // Lib ainda não carregou; tenta de novo
      setTimeout(tryInit, 200);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", tryInit);
  } else {
    tryInit();
  }

  // SPA re-mount support
  document.addEventListener("astro:page-load", tryInit);
</script>
