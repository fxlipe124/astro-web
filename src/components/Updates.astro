---
// Changelog público — texto curto, mais recente primeiro. Editar manualmente
// quando algo digno de menção rola (deploy de patch, novo evento, decisão de
// produto). Itens muito técnicos ou internos NÃO vão aqui; isso é pra
// jogadores entenderem o que mudou pro lado deles.

const updates = [
  {
    date: "2026-05-13",
    tag: "loja",
    title: "Migração pra UltimateShop",
    body:
      "Saímos do EasyShopGUI pra UltimateShop — plugin FOSS, mais leve, melhor manutenção.",
  },
  {
    date: "2026-05-10",
    tag: "site",
    title: "Site no ar",
    body:
      "astro-web publicado. Theme toggle dark/light, player do SoundCloud, ilhas pixel-art.",
  },
  {
    date: "2026-05-01",
    tag: "infra",
    title: "Crossplay Java + Bedrock",
    body:
      "Mesma porta padrão pra todo mundo. Java pirata também — com /register e /login.",
  },
];

// Formata "2026-05-13" → "13 maio" (mais legível, evita zero-padding no dia).
const fmt = (iso: string) => {
  const [y, m, d] = iso.split("-").map((n) => parseInt(n, 10));
  const meses = [
    "jan", "fev", "mar", "abr", "mai", "jun",
    "jul", "ago", "set", "out", "nov", "dez",
  ];
  return `${d} ${meses[m - 1]}`;
};
---

<section
  id="updates"
  class="relative scroll-mt-20 px-6 py-20 md:px-10 md:py-28"
  style="background: var(--bg-base);"
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <div
          class="mono text-xs font-semibold tracking-[0.25em] uppercase"
          style="color: var(--accent);"
        >
          ▸ atualizações
        </div>
        <h2
          class="display mt-3 text-4xl font-extrabold md:text-5xl"
          style="color: var(--text);"
        >
          O que mudou.
        </h2>
      </div>
      <p class="mono max-w-md text-sm" style="color: var(--text-dim);">
        Notas curtas sobre o que rolou. Mais recente primeiro.
      </p>
    </div>

    <ol class="flex flex-col">
      {
        updates.map((u, i) => (
          <li
            class={`flex flex-col gap-2 border-l-2 py-5 pl-6 md:flex-row md:items-start md:gap-8 md:py-6 ${i > 0 ? "border-t" : ""}`}
            style="border-color: var(--border);"
          >
            <div class="flex shrink-0 items-center gap-3 md:w-48 md:flex-col md:items-start md:gap-1">
              <span
                class="mono text-[0.65rem] font-bold tracking-[0.2em] uppercase"
                style="color: var(--text);"
              >
                {fmt(u.date)}
              </span>
              <span
                class="mono text-[0.55rem] font-bold tracking-[0.25em] uppercase"
                style="color: var(--accent);"
              >
                {u.tag}
              </span>
            </div>
            <div class="flex flex-col gap-1.5">
              <h3 class="display text-lg font-extrabold leading-tight md:text-xl" style="color: var(--text);">
                {u.title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: var(--text-dim);">
                {u.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
