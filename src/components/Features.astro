---
import Block from "./Block.astro";

// All colors come from CSS vars defined in base.css (--bg-base, --text, etc).
// Theme switch happens via [data-theme] on <html>.

const features = [
  {
    block: "grass" as const,
    title: "Sua ilha entre planetas",
    body: "Cada jogador começa com uma ilha 3×3 no vazio do espaço. Expanda, automatize, decore — e suba na hierarquia das constelações.",
  },
  {
    block: "emerald" as const,
    title: "Missões com nomes do jogo",
    body: "Os nomes dos itens nas missões são os mesmos que aparecem no seu inventário. Sem 'Espada Lendária' onde você só vê uma Espada de Ferro.",
  },
  {
    block: "diamond" as const,
    title: "Quatro moedas, quatro caminhos",
    body: "Money (do real), Gemas (das missões), Fragmentos (das dungeons) e Tokens (do trabalho). Cada uma tem seu próprio fluxo — comprar dinheiro real não desbloqueia o que o gameplay desbloqueia.",
  },
  {
    block: "amethyst" as const,
    title: "Crossplay verdadeiro",
    body: "Java original, pirata e Bedrock no mesmo lobby. Login com senha, skin preservada, todas as versões do jogo suportadas.",
  },
  {
    block: "obsidian" as const,
    title: "Backups diários",
    body: "Sua ilha é salva todos os dias. Não some por queda de energia, update mal calibrado ou bug raro.",
  },
  {
    block: "deepslate" as const,
    title: "Anti-grief & punições",
    body: "Logs de bloco, proteção de ilha, banimentos transparentes — sem moderador apagando histórico.",
  },
];
---

<section
  id="sistema"
  class="relative scroll-mt-20 px-6 py-20 md:px-10 md:py-28"
  style="background: var(--bg-base);"
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <div
          class="mono text-xs font-semibold tracking-[0.25em] uppercase"
          style="color: var(--accent);"
        >
          ▸ o sistema
        </div>
        <h2
          class="display mt-3 text-4xl font-extrabold md:text-5xl"
          style="color: var(--text);"
        >
          Decisões que dão pra defender.
        </h2>
      </div>
      <p class="mono max-w-md text-sm" style="color: var(--text-dim);">
        Nomes do jogo, economia justa, backups diários. Decisões que dão pra explicar.
      </p>
    </div>

    <div
      class="grid gap-px md:grid-cols-2 lg:grid-cols-3"
      style="background: var(--border);"
    >
      {
        features.map((f) => (
          <article
            class="group flex flex-col gap-5 p-7"
            style="background: var(--bg-base);"
          >
            <div class="flex items-center justify-between">
              <div class="shrink-0 transition-transform duration-500 group-hover:-translate-y-1 group-hover:rotate-3">
                <Block palette={f.block} size={56} />
              </div>
              <span
                class="mono text-[0.6rem] font-bold tracking-[0.25em] uppercase"
                style="color: var(--text-muted);"
              >
                ✦
              </span>
            </div>

            <h3
              class="display text-2xl font-extrabold leading-tight"
              style="color: var(--text);"
            >
              {f.title}
            </h3>

            <p class="text-sm leading-relaxed" style="color: var(--text-dim);">
              {f.body}
            </p>

            <div
              class="mt-auto h-px w-10 transition-all duration-500 group-hover:w-full"
              style="background: var(--accent);"
            />
          </article>
        ))
      }
    </div>
  </div>
</section>
